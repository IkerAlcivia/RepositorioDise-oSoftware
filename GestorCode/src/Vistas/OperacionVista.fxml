<AnchorPane id="AnchorPane" prefHeight="401.0" prefWidth="559.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.edu.uacm.ise.slt.ds.gestorcode.OperacionVistaController">
